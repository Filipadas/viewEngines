extends layout

block content
  style.
    body {
      font-family: 'Segoe UI', Arial, sans-serif;
      background: #0f172a;
      margin: 0;
      color: #fff;
    }

    .container {
      max-width: 1100px;
      margin: auto;
      padding: 20px;
    }

    .hero {
      text-align: center;
      padding: 40px 20px;
      background: linear-gradient(135deg, #00a3e0, #000);
      border-radius: 12px;
      margin-bottom: 30px;
    }

    .hero h1 {
      font-size: 40px;
      margin-bottom: 10px;
    }

    .hero p {
      font-size: 18px;
      opacity: 0.9;
    }

    .section {
      margin-bottom: 30px;
    }

    .section h2 {
      border-left: 5px solid #00a3e0;
      padding-left: 10px;
      margin-bottom: 15px;
    }

    .cards {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 15px;
    }

    .card {
      background: #1e293b;
      padding: 20px;
      border-radius: 10px;
      transition: 0.3s;
    }

    .card:hover {
      transform: translateY(-5px);
      background: #334155;
    }

    .card h3 {
      margin: 0;
      font-size: 18px;
    }

    .titulos-list {
      list-style: none;
      padding: 0;
    }

    .titulos-list li {
      background: #1e293b;
      margin-bottom: 10px;
      padding: 12px;
      border-radius: 8px;
    }

  .container

    // HERO
    .hero
      h1 Grêmio Foot-Ball Porto Alegrense
      p Um dos maiores clubes do Brasil 🇧🇷

    // HISTÓRIA
    .section
      h2 História
      p
        | Fundado em 1903, o Grêmio é um dos clubes mais tradicionais do futebol brasileiro.
        | Conhecido por sua garra e imortalidade, o clube conquistou títulos importantes
        | nacionais e internacionais ao longo de sua história.

    // JOGADORES
    .section
      h2 Ídolos do Clube
      .cards
        .card
          h3 Renato Gaúcho
        .card
          h3 Ronaldinho Gaúcho
        .card
          h3 Danrlei
        .card
          h3 Geromel
        .card
          h3 Luan

    // TÍTULOS
    .section
      h2 Principais Títulos
      ul.titulos-list
        li Libertadores da América (3x)
        li Campeonato Brasileiro (2x)
        li Copa do Brasil (5x)
        li Recopa Sul-Americana (2x)