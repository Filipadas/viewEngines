extends layout

block content
  style.
    body {
      font-family: 'Segoe UI', Arial;
      background: #111827;
      color: white;
      margin: 0;
    }

    .navbar {
      display: flex;
      justify-content: center;
      gap: 15px;
      background: #000;
      padding: 15px;
    }

    .nav-btn {
      text-decoration: none;
      color: white;
      background: #a50044;
      padding: 8px 15px;
      border-radius: 8px;
    }

    .nav-btn:hover {
      background: #004d98;
    }

    .container {
      max-width: 900px;
      margin: auto;
      padding: 30px;
    }

    .lista {
      display: flex;
      flex-direction: column;
      gap: 15px;
    }

    .item {
      background: #1f2937;
      padding: 15px;
      border-radius: 10px;
      transition: 0.3s;
    }

    .item:hover {
      background: #374151;
      transform: scale(1.02);
    }

  .navbar
    a.nav-btn(href="/barcelona") História
    a.nav-btn(href="/barcelona/jogadores") Jogadores
    a.nav-btn(href="/barcelona/titulos") Títulos

  .container
    h1 Títulos do Barcelona

    .lista
      .item Champions League (5x)
      .item La Liga (27x)
      .item Copa do Rei (31x)