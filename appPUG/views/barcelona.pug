extends layout

block content
  style.
    body {
      font-family: 'Segoe UI', Arial;
      background: #111827;
      color: white;
      margin: 0;
    }

    .navbar {
      display: flex;
      justify-content: center;
      gap: 15px;
      background: #000;
      padding: 15px;
    }

    .nav-btn {
      text-decoration: none;
      color: white;
      background: #a50044;
      padding: 8px 15px;
      border-radius: 8px;
      transition: 0.3s;
    }

    .nav-btn:hover {
      background: #004d98;
    }

    .container {
      max-width: 1000px;
      margin: auto;
      padding: 30px;
    }

    .hero {
      background: linear-gradient(135deg, #a50044, #004d98);
      padding: 40px;
      border-radius: 12px;
      text-align: center;
      margin-bottom: 30px;
    }

    .content {
      background: #1f2937;
      padding: 25px;
      border-radius: 10px;
      line-height: 1.6;
    }

  .navbar
    a.nav-btn(href="/barcelona") História
    a.nav-btn(href="/barcelona/jogadores") Jogadores
    a.nav-btn(href="/barcelona/titulos") Títulos

  .container
    .hero
      h1 FC Barcelona
      p História de um gigante europeu

    .content
      p Fundado em 1899, o FC Barcelona é um dos clubes mais importantes do mundo.
      p Conhecido pelo estilo "tiki-taka" e pela sua filosofia única.